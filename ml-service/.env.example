# ML Service – copy this to .env and fill in your values
# python -m venv venv && venv\Scripts\activate && pip install -r requirements.txt

GOOGLE_API_KEY=your_gemini_api_key_here

# Set to "0" on Render free tier (512MB RAM) to disable sentence-transformers
# and use lightweight TF-IDF instead (saves ~300MB RAM, prevents OOM crashes)
# Set to "1" (default) on paid plans for better semantic similarity accuracy
SEMANTIC_MODEL_SHARED=0

# Optional – only needed if running directly with python app.py
# PORT=8000
# FLASK_DEBUG=false
